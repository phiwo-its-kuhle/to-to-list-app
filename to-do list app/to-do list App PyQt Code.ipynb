    import sys
    from PyQt5.QtWidgets import QDialog, QApplication
    from toDoListApp import *
   
    class MyForm(QDialog):
        def __init__(self):
            super().__init__()
            self.ui = Ui_Dialog()
            self.ui.setupUi(self)
            self.ui.pushButtonAccept.clicked.connect(self.welcomeMsg)
            self.ui.pushButtonAddTask.clicked.connect(self.enterTask)
            self.ui.listWidgetToDoList.itemSelectionChanged.connect(self.completedTasks)
            self.ui.pushButtonDelCompletedTasls.clicked.connect(self.undoneTask)
            self.show()
    
        def welcomeMsg(self):
            name = self.ui.lineEditName.text()
            surname = self.ui.lineEditSurname.text()
            day = self.ui.lineEditDay.text()
            self.ui.labelDetails.setText(f"Welcome {name} {surname}\n To-do List for: {day}")
    
        def enterTask(self):
            task = self.ui.lineEditEnterTask.text()    
            if self.ui.listWidgetToDoList.count() > 8:
                self.ui.lineEditEnterTask.setText("Limit no. Tasks reached!")
            else:
                self.ui.listWidgetToDoList.addItem(task)
                self.ui.lineEditEnterTask.clear()
    
        def completedTasks(self):
            items = self.ui.listWidgetToDoList.selectedItems()
            for i in items:
                self.ui.listWidgetCompletedTasks.addItem(i.text())
    
        def undoneTask(self):
            tasks = self.ui.listWidgetCompletedTasks.selectedItems()
            for t in tasks:
                row = self.ui.listWidgetCompletedTasks.row(t)
                self.ui.listWidgetCompletedTasks.takeItem(row)
    
    
    if __name__ == "__main__":
        app = QApplication(sys.argv)
        myApp = MyForm()
        myApp.show()
        sys.exit(app.exec_())
 